# deploy/.env.example — 复制为 .env 并填入实际值（.env 已被 gitignore）

# Proxmox（只读用户 + API Token 创建方法见 README「在 PVE 中创建只读用户」）
PVE_URL=https://192.168.1.2:8006
PVE_TOKEN_ID=hearth@pve!monitor
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Docker（容器内通过挂载的 socket 访问，通常无需修改）
DOCKER_HOST=unix:///var/run/docker.sock
# 宿主机 docker.sock 的属组 GID：stat -c %g /var/run/docker.sock
DOCKER_GID=999

# ImmortalWrt（LuCI 登录账号；建议单独建一个只读账号）
OPENWRT_URL=http://192.168.1.1
OPENWRT_USERNAME=root
OPENWRT_PASSWORD=change-me

# 可选
HEARTH_POLL_INTERVAL=10s
# 设备 Ping/TCP/HTTP 健康检查周期
HEARTH_HEALTH_INTERVAL=30s
# 可选：以逗号分隔的 ARP 扫描网段。留空时自动扫描 NAS 所在本地网段。
# HEARTH_SCAN_NETWORKS=192.168.1.0/24,192.168.10.0/24
# 由 Compose 部署模式设置；标准网络模式=false，主机网络模式=true。
# HEARTH_ARP_DISCOVERY_ENABLED=true
HEARTH_LISTEN=:8080
HEARTH_DATA_DIR=/data
